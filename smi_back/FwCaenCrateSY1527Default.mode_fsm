class: $FWPART_FwCaenCrateSY1527Default_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWCAENCRATESY1527DEFAULT_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWCAENCRATESY1527DEFAULT_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWCAENCRATESY1527DEFAULT_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWCAENCRATESY1527DEFAULT_FWSETACTIONS
            move_to READY

object: $FWPART_FwCaenCrateSY1527Default_FWDM is_of_class $FWPART_FwCaenCrateSY1527Default_FwDevMode_CLASS

