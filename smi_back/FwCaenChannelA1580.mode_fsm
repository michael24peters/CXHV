class: $FWPART_FwCaenChannelA1580_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELA1580_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELA1580_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELA1580_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELA1580_FWSETACTIONS
            move_to READY

object: $FWPART_FwCaenChannelA1580_FWDM is_of_class $FWPART_FwCaenChannelA1580_FwDevMode_CLASS

