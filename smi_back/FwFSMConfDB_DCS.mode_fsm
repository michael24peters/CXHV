class: $FWPART_FwFSMConfDB_DCS_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWFSMCONFDB_DCS_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWFSMCONFDB_DCS_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWFSMCONFDB_DCS_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWFSMCONFDB_DCS_FWSETACTIONS
            move_to READY

object: $FWPART_FwFSMConfDB_DCS_FWDM is_of_class $FWPART_FwFSMConfDB_DCS_FwDevMode_CLASS

