class: $FWPART_DAQ_Domain_v1_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_DAQ_DOMAIN_V1_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_DAQ_DOMAIN_V1_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_DAQ_DOMAIN_V1_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_DAQ_DOMAIN_V1_FWSETACTIONS
            move_to READY

object: $FWPART_DAQ_Domain_v1_FWDM is_of_class $FWPART_DAQ_Domain_v1_FwDevMode_CLASS

