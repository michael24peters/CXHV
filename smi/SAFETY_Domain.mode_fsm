class: $FWPART_SAFETY_Domain_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_SAFETY_DOMAIN_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_SAFETY_DOMAIN_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_SAFETY_DOMAIN_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_SAFETY_DOMAIN_FWSETACTIONS
            move_to READY

object: $FWPART_SAFETY_Domain_FWDM is_of_class $FWPART_SAFETY_Domain_FwDevMode_CLASS

