            move_to RAMPING_STANDBY1
    state: RAMPING_STANDBY2
    !color: FwStateAttention2
        when ( $ALL$FwCHILDREN in_state STANDBY2 )  move_to STANDBY2
        when ( $ANY$FwCHILDREN not_in_state {RAMPING_STANDBY2,STANDBY2} )  move_to NOT_READY
