            endif
            move_to RAMPING_STANDBY2
    state: RAMPING_READY
    !color: FwStateAttention2
        when ( $ALL$FwCHILDREN in_state READY )  move_to READY
        when ( $ANY$FwCHILDREN not_in_state {RAMPING_READY,READY} )  move_to NOT_READY
        action: Do_Emergency_OFF	!visible: 1
            do Do_Emergency_OFF $ALL$FwCHILDREN
            if (  $ANY$FwCHILDREN not_in_state EMERGENCY_OFF )  then
