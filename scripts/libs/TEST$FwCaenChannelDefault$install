#uses "FwCaenChannelDefault.ctl"
TEST_CAEN_cxcaen01_board01_channel000_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel000");
   if(!globalExists("FwCaenChannelDefault_CurrDUActions"))
   {
      addGlobal("FwCaenChannelDefault_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwCaenChannelDefault",FwCaenChannelDefault_CurrDUActions);
   }
   FwCaenChannelDefault_initialize("TEST", devdp);
   fwDU_setDefaultParameters("TEST", devdp);
   if(dpConnect("cbTEST_CAEN_cxcaen01_board01_channel000_valueChanged",
      devdp+".actual.status:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
   if(dpConnect("cbTEST_CAEN_cxcaen01_board01_channel000_doCommand",false,
     "TEST|CAEN/cxcaen01/board01/channel000.fsm.sendCommand:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect command");
}

TEST_CAEN_cxcaen01_board01_channel000_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling TEST CAEN/cxcaen01/board01/channel000");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel000");
   if(dpDisconnect("cbTEST_CAEN_cxcaen01_board01_channel000_valueChanged",
      devdp+".actual.status:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
   if(dpDisconnect("cbTEST_CAEN_cxcaen01_board01_channel000_doCommand",
     "TEST|CAEN/cxcaen01/board01/channel000.fsm.sendCommand:_online.._value"
     ) == -1 )
      DebugN("Bad dpDisconnect command");
}

cbTEST_CAEN_cxcaen01_board01_channel000_valueChanged(
      string dp1, int x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel000");
   fwDU_convertValue("TEST","CAEN/cxcaen01/board01/channel000");
   FwCaenChannelDefault_valueChanged("TEST", devdp,
      x1, state );
   fwDU_setState("TEST", devdp, state);
}

cbTEST_CAEN_cxcaen01_board01_channel000_doCommand(string dp, string command)
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel000");
   command = fwDU_convertCommand("TEST","CAEN/cxcaen01/board01/channel000","FwCaenChannelDefault", FwCaenChannelDefault_CurrDUActions, command);
   FwCaenChannelDefault_doCommand("TEST", devdp, command);
}

