#uses "FwCaenChannelDefault.ctl"
CXHV_CAEN_cxcaen01_board01_channel011_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel011");
   if(!globalExists("FwCaenChannelDefault_CurrDUActions"))
   {
      addGlobal("FwCaenChannelDefault_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwCaenChannelDefault",FwCaenChannelDefault_CurrDUActions);
   }
   FwCaenChannelDefault_initialize("CXHV", devdp);
   fwDU_setDefaultParameters("CXHV", devdp);
   if(dpConnect("cbCXHV_CAEN_cxcaen01_board01_channel011_valueChanged",
      devdp+".actual.status:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
   if(dpConnect("cbCXHV_CAEN_cxcaen01_board01_channel011_doCommand",false,
     "CXHV|CAEN/cxcaen01/board01/channel011.fsm.sendCommand:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect command");
}

CXHV_CAEN_cxcaen01_board01_channel011_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CXHV CAEN/cxcaen01/board01/channel011");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel011");
   if(dpDisconnect("cbCXHV_CAEN_cxcaen01_board01_channel011_valueChanged",
      devdp+".actual.status:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
   if(dpDisconnect("cbCXHV_CAEN_cxcaen01_board01_channel011_doCommand",
     "CXHV|CAEN/cxcaen01/board01/channel011.fsm.sendCommand:_online.._value"
     ) == -1 )
      DebugN("Bad dpDisconnect command");
}

cbCXHV_CAEN_cxcaen01_board01_channel011_valueChanged(
      string dp1, int x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel011");
   fwDU_convertValue("CXHV","CAEN/cxcaen01/board01/channel011");
   FwCaenChannelDefault_valueChanged("CXHV", devdp,
      x1, state );
   fwDU_setState("CXHV", devdp, state);
}

cbCXHV_CAEN_cxcaen01_board01_channel011_doCommand(string dp, string command)
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board01/channel011");
   command = fwDU_convertCommand("CXHV","CAEN/cxcaen01/board01/channel011","FwCaenChannelDefault", FwCaenChannelDefault_CurrDUActions, command);
   FwCaenChannelDefault_doCommand("CXHV", devdp, command);
}

