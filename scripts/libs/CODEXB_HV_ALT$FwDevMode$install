#uses "FwDevMode.ctl"
CODEXB_HV_ALT_CODEXB_HV_ALT_LEFT_GROUND_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_HV_ALT/LEFT_GROUND_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_HV_ALT", devdp);
   fwDU_setDefaultParameters("CODEXB_HV_ALT", devdp);
   if(dpConnect("cbCODEXB_HV_ALT_CODEXB_HV_ALT_LEFT_GROUND_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_HV_ALT_CODEXB_HV_ALT_LEFT_GROUND_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_HV_ALT CODEXB_HV_ALT/LEFT_GROUND_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_HV_ALT/LEFT_GROUND_FWDM");
   if(dpDisconnect("cbCODEXB_HV_ALT_CODEXB_HV_ALT_LEFT_GROUND_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_HV_ALT_CODEXB_HV_ALT_LEFT_GROUND_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_HV_ALT/LEFT_GROUND_FWDM");
   fwDU_convertValue("CODEXB_HV_ALT","CODEXB_HV_ALT/LEFT_GROUND_FWDM");
   FwDevMode_valueChanged("CODEXB_HV_ALT", devdp,
      x1, state );
   fwDU_setState("CODEXB_HV_ALT", devdp, state);
}

