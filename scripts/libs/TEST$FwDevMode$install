#uses "FwDevMode.ctl"
TEST_TEST_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("TEST_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("TEST", devdp);
   fwDU_setDefaultParameters("TEST", devdp);
   if(dpConnect("cbTEST_TEST_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

TEST_TEST_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling TEST TEST_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("TEST_FWDM");
   if(dpDisconnect("cbTEST_TEST_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbTEST_TEST_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("TEST_FWDM");
   fwDU_convertValue("TEST","TEST_FWDM");
   FwDevMode_valueChanged("TEST", devdp,
      x1, state );
   fwDU_setState("TEST", devdp, state);
}

