"/* **************************************************************************************

Author: Bruno Belbute
Date:   12.05.2006
NOTE:   Create standard RECIPES

*************************************************************************************** */

string node, mode;
string hierarchyType;

dyn_string SavePopertiesNames;
dyn_string SavePopertiesValuesSB1;
dyn_string SavePopertiesValuesSB2;
dyn_string SavePopertiesValuesRDY;
dyn_int    SavePopertiesTypes;

dyn_string DataPointsDPNames;
dyn_string DataPointsDPTypes;

dyn_string RecipeValuesSB1;
dyn_string RecipeValuesSB2;
dyn_string RecipeValuesRDY;

/* ************************************************************************************ */

main()
{
	getValue (\"CUNAME\", \"text\", node);
	getValue (\"MODE\"  , \"text\", mode);
/*
	if (RadioButton1.number == \"0\")
	{
		hierarchyType = fwDevice_HARDWARE;
	}
	else
	if (RadioButton1.number == \"1\")
	{
		hierarchyType = fwDevice_LOGICAL;
	}
*/
	GETSAVEPROPERTIES ();

	GETDPS (node);

	GETDPES ();

	CREATERECIPECACHES ();

	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> END\");
}

/* ************************************************************************************ */

void GETSAVEPROPERTIES ()
{
	string i0value, rDvalue, rUvalue, tTvalue, v0SB1value, v0SB2value, v0RDYvalue, vMvalue;

	getValue ( \"i0\"    , \"text\" , i0value    );
	getValue ( \"v0SB1\" , \"text\" , v0SB1value );
	getValue ( \"v0SB2\" , \"text\" , v0SB2value );
	getValue ( \"v0RDY\" , \"text\" , v0RDYvalue );
	getValue ( \"rD\"    , \"text\" , rDvalue    );
	getValue ( \"rU\"    , \"text\" , rUvalue    );
	getValue ( \"tT\"    , \"text\" , tTvalue    );
	getValue ( \"vM\"    , \"text\" , vMvalue    );

	SavePopertiesNames = makeDynString (
		\".settings.i0\"       ,
		\".settings.i1\"       ,
		\".settings.onOff\"    ,
		\".settings.rDwn\"     ,
		\".settings.rUp\"      ,
		\".settings.tripTime\" ,
		\".settings.v0\"       ,
		\".settings.v1\"       ,
		\".settings.vMaxSoftValue\" );

	SavePopertiesValuesSB1 = makeDynString (
		i0value    ,
		\"0\"        ,
		\"TRUE\"     ,
		rDvalue    ,
		rUvalue    ,
		tTvalue    ,
		v0SB1value ,
		\"0\"        ,
		vMvalue );

	SavePopertiesValuesSB2 = makeDynString (
		i0value    ,
		\"0\"        ,
		\"TRUE\"     ,
		rDvalue    ,
		rUvalue    ,
		tTvalue    ,
		v0SB2value ,
		\"0\"        ,
		vMvalue );

	SavePopertiesValuesRDY = makeDynString (
		i0value    ,
		\"0\"        ,
		\"TRUE\"     ,
		rDvalue    ,
		rUvalue    ,
		tTvalue    ,
		v0RDYvalue ,
		\"0\"        ,
		vMvalue );

	SavePopertiesTypes = makeDynInt (
		22 ,
		22 ,
		23 ,
		22 ,
		22 ,
		22 ,
		22 ,
		22 ,
		22 );

	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> Save Properties created!!\");
}

/* ************************************************************************************ */

void GETDPS (string node)
{
	dyn_string allFSMDevices;
	dyn_string allChildren;
	dyn_int allChildrenTypes; //1 = CU, 2 = DU, 0 = Obj or LU
	string DUName;
	string type;
	int CU, LU;
	int position;
	dyn_string typeDeviceAll = makeDynString (typeFSMCaen, \"FwCaenChannelA1580Default\");

	allChildren = fwCU_getChildren (allChildrenTypes, node);

	if (dynlen(allChildren) == 0)
	{
		DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> No DU to include on the RecipeCache for node \" + node + \"!!\");
		return;
	}

	//Add the current node children's
	for (int i = 1; i <= dynlen(allChildren); i++)
	{
		fwCU_getType (allChildren[i], type);
		position = dynContains (typeDeviceAll, type);
		if (position > 0)
		{
/*
			if (hierarchyType == fwDevice_HARDWARE)
			{
				DUName = getSystemName() + allChildren[i];
			}
			else
			if (hierarchyType == fwDevice_LOGICAL)
			{
				DUName = allChildren[i];
			}
*/
                        if(fwFsm_isLogicalDeviceName(allChildren[i]))
				DUName = allChildren[i];
                        else
				DUName = getSystemName() + allChildren[i];
			dynAppend (DataPointsDPNames, DUName);
			dynAppend (DataPointsDPTypes, type);
		}
	}
	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> All DU's for node \" + node + \" included!!\");

	//For the CU
	while ( (CU = dynContains (allChildrenTypes, 1)) > 0 )
	{
		allChildrenTypes[CU] = -1;
		GETDPS (allChildren[CU]);
	}

	//For the LU
	while ( (LU = dynContains (allChildrenTypes, 0)) > 0 )
	{
		allChildrenTypes[LU] = -1;
		GETDPS (allChildren[LU]);
	}
DebugTN(__FUNCTION__, __LINE__, DataPointsDPNames, DataPointsDPTypes);
}


void GETDPES ()
{
	for (int i=1; i<=dynlen(DataPointsDPNames); i++)
	{
		for (int j=1; j<=dynlen(SavePopertiesNames); j++)
		{
			dynAppend (RecipeValuesSB1, SavePopertiesValuesSB1[j]);
			dynAppend (RecipeValuesSB2, SavePopertiesValuesSB2[j]);
			dynAppend (RecipeValuesRDY, SavePopertiesValuesRDY[j]);
		}
	}

	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> All DU DPE's for node \" + node + \" included!!\");
}


void CREATERECIPECACHES ()
{
	dyn_dyn_mixed recipeObject;
	dyn_dyn_mixed oldObject;
	dyn_dyn_mixed finalObject;
	dyn_string deviceList;
	dyn_string exInfo;

	//Initialization
	fwConfigurationDB_initialize (\"\", exInfo);

	//Create Hierarchy
	deviceList = DataPointsDPNames;

	//Set the recipe type
	fwConfigurationDB_setRecipeType (\"CaenHVChannelRecipeType\", exInfo);

	//Get the recipe data
	fwConfigurationDB_extractRecipe (deviceList, hierarchyType, recipeObject, exInfo);
	//Command Go_STANDBY1
	recipeObject[fwConfigurationDB_RO_VALUE] = RecipeValuesSB1;

	fwConfigurationDB_loadRecipeFromCache(mode + \"/Go_STANDBY1\", makeDynString(), hierarchyType, oldObject, exInfo);
        dynClear(exInfo);
        if(dynlen(oldObject[fwConfigurationDB_RO_VALUE]))
        {
	  fwConfigurationDB_combineRecipes(finalObject, recipeObject, oldObject, exInfo);
	  fwConfigurationDB_saveRecipeToCache(finalObject, hierarchyType, mode + \"/Go_STANDBY1\", exInfo);
        }
        else
          fwConfigurationDB_saveRecipeToCache(recipeObject, hierarchyType, mode + \"/Go_STANDBY1\", exInfo);

	//Command Go_STANDBY2
	recipeObject[fwConfigurationDB_RO_VALUE] = RecipeValuesSB2;

	fwConfigurationDB_loadRecipeFromCache(mode + \"/Go_STANDBY2\", makeDynString(), hierarchyType, oldObject, exInfo);
        dynClear(exInfo);
        if(dynlen(oldObject[fwConfigurationDB_RO_VALUE]))
        {
	  fwConfigurationDB_combineRecipes(finalObject, recipeObject, oldObject, exInfo);
	  fwConfigurationDB_saveRecipeToCache(finalObject, hierarchyType, mode + \"/Go_STANDBY2\", exInfo);
        }
        else
	  fwConfigurationDB_saveRecipeToCache(recipeObject, hierarchyType, mode + \"/Go_STANDBY2\", exInfo);

	//Command Go_READY
	recipeObject[fwConfigurationDB_RO_VALUE] = RecipeValuesRDY;

	fwConfigurationDB_loadRecipeFromCache(mode + \"/Go_READY\", makeDynString(), hierarchyType, oldObject, exInfo);
        dynClear(exInfo);
        if(dynlen(oldObject[fwConfigurationDB_RO_VALUE]))
        {
	  fwConfigurationDB_combineRecipes(finalObject, recipeObject, oldObject, exInfo);
	  fwConfigurationDB_saveRecipeToCache(finalObject, hierarchyType, mode + \"/Go_READY\", exInfo);
        }
        else
    	  fwConfigurationDB_saveRecipeToCache(recipeObject, hierarchyType, mode + \"/Go_READY\", exInfo);

	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 2 -> Standard Recipes created!!\");
}
