"main()
{
	//CAEN
	setValue ( \"i0\"    , \"text\" , \"10\"  );
	setValue ( \"v0SB1\" , \"text\" , \"200\" );
	setValue ( \"v0SB2\" , \"text\" , \"400\" );
	setValue ( \"v0RDY\" , \"text\" , \"600\" );
	setValue ( \"rD\"    , \"text\" , \"75\"  );
	setValue ( \"rU\"    , \"text\" , \"75\"  );
	setValue ( \"tT\"    , \"text\" , \"3\"   );
	setValue ( \"vM\"    , \"text\" , \"600\" );

	setValue (\"Texti0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.i0\"));
	setValue (\"TextrD\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rDwn\"));
	setValue (\"TextrU\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rUp\"));
	setValue (\"TexttT\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.tripTime\"));
	setValue (\"TextSB1\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" STANDBY_1\");
	setValue (\"TextSB2\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" STANDBY_2\");
	setValue (\"TextRDY\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" READY\");
	setValue (\"TextvM\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.vMaxSoftValue\"));
	
	setValue (\"i0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.i0\"));
	setValue (\"rD\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rDwn\"));
	setValue (\"rU\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rUp\"));
	setValue (\"tT\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.tripTime\"));
	setValue (\"v0SB1\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" STANDBY_1\");
	setValue (\"v0SB2\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" STANDBY_2\");
	setValue (\"v0RDY\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\") + \" READY\");
	setValue (\"vM\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.vMaxSoftValue\"));
