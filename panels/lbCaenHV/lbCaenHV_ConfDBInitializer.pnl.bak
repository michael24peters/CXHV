""0  1
E "#uses \"fwFSM/fwFsm.ctl\"

/* PANEL VARIABLES ************************************************************************/
const string typeDPCaen = \"FwCaenChannel\";

const string typeFSMCaen = \"FwCaenChannelDefault\";


/* Receives the data point type and the data point element and returns the dpe name ******/
string getDpeName(string dptype, string dpe)
{
	dyn_string exceptionInfo;
	dyn_string namelist;
	dyn_string dpelist;
	string definitionDp;
	int index;

	fwDevice_getDefinitionDp(makeDynString(\"\", dptype, \"\", \"\"), definitionDp, exceptionInfo);
	if (dynlen(exceptionInfo)) return \"\";

	dpGet(definitionDp + \".properties.names\", namelist, definitionDp + \".properties.dpes\", dpelist);

	index = dynContains(dpelist, dpe);

	if (index >0)
		return namelist[index];
	else
		return \"\";
}
